---
// Shared hero for all pages. Text + optional right-hand image (same two-column
// treatment as the home hero). Pass action buttons via the "actions" slot.
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  image?: string;
  imageAlt?: string;
}

const { eyebrow, title, text, image, imageAlt } = Astro.props;
const hasActions = Astro.slots.has('actions');
---

<section class="hero">
  <div class:list={['container', 'hero__inner', { 'hero--with-image': image }]}>
    <div class="hero__content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {text && <p>{text}</p>}
      {
        hasActions && (
          <div class="hero__actions">
            <slot name="actions" />
          </div>
        )
      }
    </div>

    {
      image && (
        <div class="hero__media">
          <img src={image} alt={imageAlt ?? ''} width="640" height="480" loading="eager" />
        </div>
      )
    }
  </div>
</section>
