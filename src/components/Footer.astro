---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <div class="footer-brand">
        <img src="/favicon.svg" alt="" width="26" height="26" />
        <span>Smashing <strong>'72</strong></span>
      </div>
      <p class="muted-light">
        A friendly non-profit volleyball club — all ages, all levels welcome.
      </p>
    </div>

    <div>
      <h3>Explore</h3>
      <ul>
        <li><a href="/news">News</a></li>
        <li><a href="/teams">Our teams</a></li>
        <li><a href="/about">About the club</a></li>
        <li><a href="/join">Join us</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div>
      <h3>Find us</h3>
      <ul>
        <li>Sports Hall, Example Street 1</li>
        <li>1234 AB, Your Town</li>
        <li><a href="mailto:info@smashing72.example">info@smashing72.example</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bar">
    <div class="container">
      <p>&copy; {year} Smashing '72 Volleyball Club. Non-profit sports association.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: rgba(255, 255, 255, 0.8);
    margin-top: 3rem;
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1.4fr 1fr 1fr;
    padding-block: 2.75rem;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }
  .footer-brand strong {
    color: var(--red-light);
    font-weight: 800;
  }

  .muted-light {
    color: rgba(255, 255, 255, 0.65);
    max-width: 34ch;
  }

  .site-footer h3 {
    color: #fff;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .site-footer a {
    color: rgba(255, 255, 255, 0.8);
  }
  .site-footer a:hover {
    color: var(--red-light);
  }

  .footer-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-block: 1rem;
    font-size: 0.85rem;
  }
  .footer-bar p {
    margin: 0;
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
