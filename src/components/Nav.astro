---
const links = [
  { href: '/', label: 'Home' },
  { href: '/news', label: 'News' },
  { href: '/teams', label: 'Teams' },
  { href: '/about', label: 'About' },
  { href: '/join', label: 'Join' },
  { href: '/contact', label: 'Contact' },
];

// Highlight the active link (handles trailing slashes and sub-paths).
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/">
      <img src="/logo.svg" alt="" width="34" height="33" />
      <span>Smashing <strong>'72</strong></span>
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Toggle navigation menu"
    >
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>

    <nav id="primary-nav" class="nav-links" aria-label="Primary">
      <ul>
        {
          links.map((link) => {
            const target = link.href.replace(/\/+$/, '') || '/';
            const isActive =
              target === '/' ? path === '/' : path === target || path.startsWith(target + '/');
            return (
              <li>
                <a href={link.href} aria-current={isActive ? 'page' : undefined}>
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--red);
    color: #fff;
    border-bottom: 3px solid var(--red-dark);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #fff;
    font-size: 1.2rem;
    font-weight: 600;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand strong {
    color: #fff;
    font-weight: 800;
  }

  .nav-links ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    display: block;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
  }
  .nav-links a:hover {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    text-decoration: none;
  }
  .nav-links a[aria-current='page'] {
    color: #fff;
    background: rgba(0, 0, 0, 0.16);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0.5rem;
  }
  .nav-toggle__bar {
    width: 24px;
    height: 2px;
    background: #fff;
  }

  /* Mobile */
  @media (max-width: 760px) {
    .nav-toggle {
      display: flex;
    }
    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--red);
      border-bottom: 3px solid var(--red-dark);
      display: none;
    }
    .nav-links.is-open {
      display: block;
    }
    .nav-links ul {
      flex-direction: column;
      padding: 0.5rem 1.25rem 1rem;
      gap: 0.1rem;
    }
    .nav-links a {
      padding: 0.7rem 0.5rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.getElementById('primary-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  // Close the menu when a link is tapped (mobile).
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
