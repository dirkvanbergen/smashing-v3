---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">About the club</p>
      <h1>Who we are</h1>
      <p>A volunteer-run club built on community, fair play and a love of the game.</p>
    </div>
  </section>

  <section class="section">
    <div class="container stack" style="max-width: 68ch;">
      <p>
        Smashing VC is a small non-profit volleyball club. We welcome players of
        every age and ability — from first-timers picking up a ball for the first
        time to seasoned competitors chasing promotion.
      </p>

      <h2>Our mission</h2>
      <p>
        To make volleyball accessible, affordable and fun for our whole community,
        while fielding competitive teams that make the club proud.
      </p>

      <h2>What we offer</h2>
      <ul>
        <li>Recreational and competitive teams for adults</li>
        <li>Youth development groups (U14 &amp; U16)</li>
        <li>Weekly training sessions with qualified coaches</li>
        <li>A friendly, social club atmosphere off the court</li>
      </ul>

      <h2>Get involved</h2>
      <p>
        Whether you want to play, coach, or volunteer, there's a place for you.
        <a href="/contact">Reach out</a> and we'll help you find it.
      </p>
    </div>
  </section>
</BaseLayout>
