---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank you" description="Thanks — your message has been sent.">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Message sent</p>
      <h1>Thanks — we'll be in touch!</h1>
      <p>
        Your message has reached the club. A volunteer will get back to you as soon
        as we can.
      </p>
      <div class="hero__actions">
        <a class="btn btn--light" href="/">Back to home</a>
        <a class="btn btn--ghost" href="/news">Read the latest news</a>
      </div>
    </div>
  </section>
</BaseLayout>
