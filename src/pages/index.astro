---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getCollection, render } from 'astro:content';
import home from '../data/home.json';
import { getNextHomeMatchDay } from '../lib/matches.ts';

// Active announcements: hide any whose event date has already passed.
// (Build-time filter; a small client-side script below also removes any that
// pass between site rebuilds, so alternating colors/sides stay correct.)
const todayStart = new Date();
todayStart.setHours(0, 0, 0, 0);

const announcements = (await getCollection('announcements'))
  .filter((a) => a.data.date.valueOf() >= todayStart.valueOf())
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const activeAnnouncements = await Promise.all(
  announcements.map(async (item) => {
    const { Content } = await render(item);
    return { item, Content };
  })
);

const announceDateFmt = new Intl.DateTimeFormat('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Latest published news posts, newest first: one featured + a few smaller.
const news = (await getCollection('news', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featuredNews = news[0];
const moreNews = news.slice(1, 5);

// Sidebar: sponsors (CMS collection) shown alongside the news.
const sponsors = (await getCollection('sponsors')).sort(
  (a, b) => a.data.order - b.data.order
);

// Next home-match day (from the Nevobo RSS feed at build time), grouped by
// time slot. We show one date heading and all home matches that day.
const matchDay = await getNextHomeMatchDay();
const anyProvisional =
  matchDay?.slots.some((s) => s.matches.some((m) => m.provisional)) ?? false;

const matchDayFmt = new Intl.DateTimeFormat('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  timeZone: 'Europe/Amsterdam',
});
const postDateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title="Home">
  <!-- Hero -->
  <Hero
    eyebrow={home.hero.eyebrow}
    title={home.hero.title}
    text={home.hero.text}
    image={home.hero.image}
    imageAlt={home.hero.imageAlt}
  >
    <Fragment slot="actions">
      {
        home.hero.primaryLabel && (
          <a class="btn btn--light" href={home.hero.primaryHref}>
            {home.hero.primaryLabel}
          </a>
        )
      }
      {
        home.hero.secondaryLabel && (
          <a class="btn btn--ghost" href={home.hero.secondaryHref}>
            {home.hero.secondaryLabel}
          </a>
        )
      }
    </Fragment>
  </Hero>

  <!-- Announcements (temporary; auto-hide after their date) -->
  {
    activeAnnouncements.length > 0 && (
      <section class="announce-section">
        <div class="announce-list">
          {activeAnnouncements.map(({ item, Content }) => (
            <article class="announce" data-date={item.data.date.toISOString()}>
              <div class="announce__inner container">
                {item.data.image && (
                  <button
                    type="button"
                    class="announce__media poster-trigger"
                    data-full={item.data.image}
                    data-alt={item.data.title}
                    aria-label={`Enlarge poster: ${item.data.title}`}
                  >
                    <img src={item.data.image} alt={item.data.title} loading="lazy" />
                    <span class="announce__zoom" aria-hidden="true">⤢</span>
                  </button>
                )}
                <div class="announce__body">
                  <p class="announce__date">{announceDateFmt.format(item.data.date)}</p>
                  <h3>{item.data.title}</h3>
                  <div class="announce__desc">
                    <Content />
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>

        {/* Shared lightbox for full-size posters */}
        <dialog class="lightbox" id="poster-lightbox">
          <button type="button" class="lightbox__close" aria-label="Close">&times;</button>
          <img class="lightbox__img" src="" alt="" />
        </dialog>
      </section>
    )
  }

  <!-- Latest news -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="eyebrow">{home.news.eyebrow}</p>
          <h2>{home.news.heading}</h2>
        </div>
      </div>

      <div class="news-layout">
        <div class="news-main">
          {
            featuredNews && (
              <article class="card card--featured card--link">
                {featuredNews.data.cover && (
                  <img
                    class="card__media card__media--lg"
                    src={featuredNews.data.cover}
                    alt=""
                    loading="lazy"
                  />
                )}
                <div class="card__body">
                  <p class="card__meta">
                    <span class="tag-latest">Latest</span>
                    {postDateFmt.format(featuredNews.data.date)}
                  </p>
                  <h3 class="card__title-lg">
                    <a class="stretched-link" href={`/news/${featuredNews.id}`}>
                      {featuredNews.data.title}
                    </a>
                  </h3>
                  <p class="muted">{featuredNews.data.excerpt}</p>
                  <span class="read-more" aria-hidden="true">Read more &rarr;</span>
                </div>
              </article>
            )
          }

          {
            moreNews.length > 0 && (
              <div class="grid grid--2 news-more">
                {moreNews.map((post) => (
                  <article class="card card--link">
                    {post.data.cover && (
                      <img class="card__media" src={post.data.cover} alt="" loading="lazy" />
                    )}
                    <div class="card__body">
                      <p class="card__meta">{postDateFmt.format(post.data.date)}</p>
                      <h3>
                        <a class="stretched-link" href={`/news/${post.id}`}>{post.data.title}</a>
                      </h3>
                      <p class="muted">{post.data.excerpt}</p>
                    </div>
                  </article>
                ))}
              </div>
            )
          }

          <a class="news-all" href="/news">All news &rarr;</a>
        </div>

        <aside class="sidebar">
          {
            home.shop && home.shop.links?.length > 0 && (
              <div class="side-card">
                <h3 class="side-card__title">{home.shop.heading}</h3>
                {home.shop.intro && <p class="side-card__intro">{home.shop.intro}</p>}
                <div class="side-links">
                  {home.shop.links.map((link) => (
                    <a
                      class="btn btn--primary side-link"
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            )
          }

          {
            sponsors.length > 0 && (
              <div class="side-card">
                <h3 class="side-card__title">{home.sponsors?.heading ?? 'Our sponsors'}</h3>
                <div class="sponsor-grid">
                  {sponsors.map((s) => {
                    const inner = s.data.logo ? (
                      <img src={s.data.logo} alt={s.data.name} loading="lazy" />
                    ) : (
                      <span>{s.data.name}</span>
                    );
                    return s.data.url ? (
                      <a
                        class="sponsor"
                        href={s.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        title={s.data.name}
                      >
                        {inner}
                      </a>
                    ) : (
                      <div class="sponsor" title={s.data.name}>
                        {inner}
                      </div>
                    );
                  })}
                </div>
              </div>
            )
          }
        </aside>
      </div>
    </div>
  </section>

  <!-- Upcoming matches -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="eyebrow">{home.matches.eyebrow}</p>
          <h2>{home.matches.heading}</h2>
        </div>
      </div>

      {
        matchDay ? (
          <div class="matchday">
            <p class="matchday__date">{matchDayFmt.format(matchDay.date)}</p>
            {anyProvisional && (
              <p class="matchday__note">Provisional — times may still change.</p>
            )}

            {matchDay.slots.map((slot) => (
              <div class="slot">
                <div class="slot__time">{slot.time}</div>
                <div class="slot__list">
                  {slot.matches.map((m) => (
                    <div class="slot__match">
                      <strong>{m.home}</strong> vs {m.away}
                    </div>
                  ))}
                </div>
              </div>
            ))}

            <p class="muted match__source">
              Fixtures via the <a href="https://www.nevobo.nl/">Nevobo</a> competition feed.
            </p>
          </div>
        ) : (
          <p class="muted">No home matches scheduled right now — check back soon.</p>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  // 1) Remove any announcements whose date has passed since the last build.
  //    Removing the node (rather than hiding) lets CSS :nth-child re-stripe the
  //    remaining cards, keeping alternating colors/sides correct.
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  document.querySelectorAll<HTMLElement>('.announce').forEach((el) => {
    const raw = el.dataset.date;
    if (raw && new Date(raw) < today) el.remove();
  });
  const section = document.querySelector('.announce-section');
  if (section && !section.querySelector('.announce')) section.remove();

  // 2) Poster lightbox.
  const lightbox = document.getElementById('poster-lightbox') as HTMLDialogElement | null;
  const lightboxImg = lightbox?.querySelector('.lightbox__img') as HTMLImageElement | null;

  document.querySelectorAll<HTMLButtonElement>('.poster-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = btn.dataset.full ?? '';
      lightboxImg.alt = btn.dataset.alt ?? '';
      lightbox.showModal();
    });
  });

  lightbox?.querySelector('.lightbox__close')?.addEventListener('click', () => lightbox.close());
  // Click on the backdrop (outside the image) closes the lightbox.
  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) lightbox.close();
  });
  // Clear the src on close so large images don't linger in memory.
  lightbox?.addEventListener('close', () => {
    if (lightboxImg) lightboxImg.src = '';
  });
</script>
