---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import home from '../data/home.json';

// Active announcements: hide any whose event date has already passed.
// (Build-time filter; a small client-side script below also removes any that
// pass between site rebuilds, so alternating colors/sides stay correct.)
const todayStart = new Date();
todayStart.setHours(0, 0, 0, 0);

const announcements = (await getCollection('announcements'))
  .filter((a) => a.data.date.valueOf() >= todayStart.valueOf())
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const activeAnnouncements = await Promise.all(
  announcements.map(async (item) => {
    const { Content } = await render(item);
    return { item, Content };
  })
);

const announceDateFmt = new Intl.DateTimeFormat('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Latest 3 published news posts, newest first.
const news = (await getCollection('news', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latestNews = news.slice(0, 3);

// Upcoming matches, soonest first.
const matches = (await getCollection('matches')).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
);
const upcomingMatches = matches.slice(0, 4);

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  weekday: 'short',
  day: 'numeric',
  month: 'short',
});
const postDateFmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class:list={['container', 'hero__inner', { 'hero--with-image': home.hero.image }]}>
      <div class="hero__content">
        <p class="eyebrow">{home.hero.eyebrow}</p>
        <h1>{home.hero.title}</h1>
        <p>{home.hero.text}</p>
        <div class="hero__actions">
          {
            home.hero.primaryLabel && (
              <a class="btn btn--light" href={home.hero.primaryHref}>
                {home.hero.primaryLabel}
              </a>
            )
          }
          {
            home.hero.secondaryLabel && (
              <a class="btn btn--ghost" href={home.hero.secondaryHref}>
                {home.hero.secondaryLabel}
              </a>
            )
          }
        </div>
      </div>

      {
        home.hero.image && (
          <div class="hero__media">
            <img src={home.hero.image} alt={home.hero.imageAlt ?? ''} width="640" height="480" />
          </div>
        )
      }
    </div>
  </section>

  <!-- Announcements (temporary; auto-hide after their date) -->
  {
    activeAnnouncements.length > 0 && (
      <section class="announce-section">
        <div class="announce-list">
          {activeAnnouncements.map(({ item, Content }) => (
            <article class="announce" data-date={item.data.date.toISOString()}>
              <div class="announce__inner container">
                {item.data.image && (
                  <button
                    type="button"
                    class="announce__media poster-trigger"
                    data-full={item.data.image}
                    data-alt={item.data.title}
                    aria-label={`Enlarge poster: ${item.data.title}`}
                  >
                    <img src={item.data.image} alt={item.data.title} loading="lazy" />
                    <span class="announce__zoom" aria-hidden="true">⤢</span>
                  </button>
                )}
                <div class="announce__body">
                  <p class="announce__date">{announceDateFmt.format(item.data.date)}</p>
                  <h3>{item.data.title}</h3>
                  <div class="announce__desc">
                    <Content />
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>

        {/* Shared lightbox for full-size posters */}
        <dialog class="lightbox" id="poster-lightbox">
          <button type="button" class="lightbox__close" aria-label="Close">&times;</button>
          <img class="lightbox__img" src="" alt="" />
        </dialog>
      </section>
    )
  }

  <!-- Latest news -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="eyebrow">{home.news.eyebrow}</p>
          <h2>{home.news.heading}</h2>
        </div>
        <a class="btn btn--primary" href="/news">All news</a>
      </div>

      <div class="grid grid--3">
        {
          latestNews.map((post) => (
            <article class="card">
              {post.data.cover && (
                <img class="card__media" src={post.data.cover} alt="" loading="lazy" />
              )}
              <div class="card__body">
                <p class="card__meta">{postDateFmt.format(post.data.date)}</p>
                <h3>
                  <a href={`/news/${post.id}`}>{post.data.title}</a>
                </h3>
                <p class="muted">{post.data.excerpt}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Upcoming matches -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="eyebrow">{home.matches.eyebrow}</p>
          <h2>{home.matches.heading}</h2>
        </div>
      </div>

      {
        upcomingMatches.length > 0 ? (
          <div class="stack">
            {upcomingMatches.map((m) => (
              <div class="match">
                <span class="match__date">{dateFmt.format(m.data.date)}</span>
                <span class="match__teams">
                  <strong>{m.data.home}</strong> vs <strong>{m.data.away}</strong>
                </span>
                <span class={`match__badge ${m.data.isHome ? 'match__badge--home' : ''}`}>
                  {m.data.isHome ? 'Home' : 'Away'}
                </span>
              </div>
            ))}
          </div>
        ) : (
          <p class="muted">No matches scheduled right now — check back soon.</p>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  // 1) Remove any announcements whose date has passed since the last build.
  //    Removing the node (rather than hiding) lets CSS :nth-child re-stripe the
  //    remaining cards, keeping alternating colors/sides correct.
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  document.querySelectorAll<HTMLElement>('.announce').forEach((el) => {
    const raw = el.dataset.date;
    if (raw && new Date(raw) < today) el.remove();
  });
  const section = document.querySelector('.announce-section');
  if (section && !section.querySelector('.announce')) section.remove();

  // 2) Poster lightbox.
  const lightbox = document.getElementById('poster-lightbox') as HTMLDialogElement | null;
  const lightboxImg = lightbox?.querySelector('.lightbox__img') as HTMLImageElement | null;

  document.querySelectorAll<HTMLButtonElement>('.poster-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = btn.dataset.full ?? '';
      lightboxImg.alt = btn.dataset.alt ?? '';
      lightbox.showModal();
    });
  });

  lightbox?.querySelector('.lightbox__close')?.addEventListener('click', () => lightbox.close());
  // Click on the backdrop (outside the image) closes the lightbox.
  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) lightbox.close();
  });
  // Clear the src on close so large images don't linger in memory.
  lightbox?.addEventListener('close', () => {
    if (lightboxImg) lightboxImg.src = '';
  });
</script>
